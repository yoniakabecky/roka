			"muted": {
				"oklch": "oklch(0.967 0.001 286.375)",
				"hex": "#f4f4f8",
				"role": "Subtle backgrounds, sidebar"
			},
			"mutedForeground": {
				"oklch": "oklch(0.552 0.016 285.938)",
