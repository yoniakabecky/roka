	"typography": {
		"fonts": {
			"sans": "Oxanium Variable, sans-serif",
			"heading": "Oxanium Variable, sans-serif",
			"mono": "ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace"
		},
		"notes": "Oxanium is a geometric variable font with a technical, angular character — ideal for data-dense tool UIs. Noto Sans JP is available for Japanese locale support.",
		"scale": {
			"xs": {
				"size": "0.75rem",
				"lineHeight": "1rem",
				"tailwind": "text-xs",
				"usage": "Labels, metadata, table cells, button text"
			},
			"sm": {
				"size": "0.875rem",
				"lineHeight": "1.25rem",
				"tailwind": "text-sm",
				"usage": "Body text, input text, descriptions"
			},
			"base": {
				"size": "1rem",
				"lineHeight": "1.5rem",
				"tailwind": "text-base",
				"usage": "Standard reading text"
			},
			"lg": {
				"size": "1.125rem",
				"lineHeight": "1.75rem",
				"tailwind": "text-lg",
				"usage": "Section headings"
			},
			"xl": {
				"size": "1.25rem",
				"lineHeight": "1.75rem",
				"tailwind": "text-xl",
				"usage": "Page sub-headings"
			},
			"2xl": {
				"size": "1.5rem",
				"lineHeight": "2rem",
				"tailwind": "text-2xl",
				"usage": "Page titles, brand wordmark"
			}
		},
		"weights": {
			"normal": 400,
			"medium": 500,
			"semibold": 600,
			"bold": 700
		},
		"patterns": {
			"sectionLabel": "text-xs font-semibold tracking-wider uppercase text-muted-foreground",
			"bodySmall": "text-xs text-foreground",
			"metadata": "text-sm text-muted-foreground",
			"pageTitle": "text-2xl font-bold text-foreground",
			"dropZoneTitle": "text-2xl font-bold text-foreground"
		}
	},

	"spacing": {
		"scale": "4px base grid",
		"tokens": {
			"0": "0px",
			"0.5": "2px",
			"1": "4px",
			"1.5": "6px",
			"2": "8px",
			"2.5": "10px",
			"3": "12px",
			"4": "16px",
			"5": "20px",
			"6": "24px",
			"8": "32px",
			"10": "40px",
			"12": "48px"
		},
		"commonPatterns": {
			"headerHeight": "h-14 (56px)",
			"sidebarWidth": "w-64 (256px)",
			"pagePadding": "px-6 (24px horizontal)",
			"cardPadding": "p-12 (48px for drop zone)",
			"compactPadding": "px-3 py-1 (12px / 4px) — standard row padding",
			"sectionPadding": "px-4 py-2 (16px / 8px) — toolbar, stats row",
			"gutterXs": "gap-1 (4px)",
			"gutterSm": "gap-2 (8px)",
			"gutterMd": "gap-3 (12px)"
		}
	},

	"borderRadius": {
		"base": "0.45rem",
		"sm": "0.27rem  (base × 0.6)",
		"md": "0.36rem  (base × 0.8)",
		"lg": "0.45rem  (base × 1.0)",
		"xl": "0.63rem  (base × 1.4)",
		"2xl": "0.81rem  (base × 1.8)",
		"3xl": "0.99rem  (base × 2.2)",
		"4xl": "1.17rem  (base × 2.6)",
		"full": "9999px"
	},

	"shadows": {
		"note": "Shadows are minimal — this is a tool UI, not a marketing page. Elevation is conveyed through border and background contrast rather than box-shadow.",
		"sm": "0 1px 2px 0 oklch(0 0 0 / 0.05)",
		"md": "0 4px 6px -1px oklch(0 0 0 / 0.08), 0 2px 4px -2px oklch(0 0 0 / 0.05)",
		"lg": "0 10px 15px -3px oklch(0 0 0 / 0.08), 0 4px 6px -4px oklch(0 0 0 / 0.05)"
	},

	"breakpoints": {
		"sm": "640px",
		"md": "768px",
		"lg": "1024px",
		"xl": "1280px",
		"2xl": "1536px"
	},

	"animation": {
		"durationFast": "100ms",
		"durationNormal": "150ms",
		"durationSlow": "250ms",
		"easing": "cubic-bezier(0.4, 0, 0.2, 1)",
		"note": "Animations are subtle and purposeful. Transitions exist on interactive elements (buttons, hover states). No scroll animations. tw-animate-css provides utility classes."
	},

	"components": {
		"button": {
			"variants": ["default", "outline", "secondary", "ghost", "destructive", "link"],
			"sizes": {
				"icon-xs": "size-5  (20px) — inline icon-only controls",
				"icon-sm": "size-6  (24px) — small icon buttons",
				"xs": "h-5     (20px) — very compact action buttons",
				"sm": "h-6     (24px) — compact secondary buttons",
				"default": "h-7     (28px) — standard button (smaller than most design systems)",
				"lg": "h-8     (32px) — primary calls to action",
				"icon": "size-7  (28px) — standard icon button",
				"icon-lg": "size-8  (32px) — large icon button"
			},
			"note": "Button heights skew compact — the default h-7 (28px) vs the typical 36-40px in most systems. This is intentional for dense data-tool UIs."
		},
		"header": {
			"height": "h-14 (56px)",
			"padding": "px-6",
			"background": "bg-background",
			"border": "border-b border-border"
		},
		"sidebar": {
			"width": "w-64 (256px)",
			"background": "bg-muted/50",
			"border": "border-r border-border",
			"stickyHeader": "bg-muted with border-b"
		},
		"dropzone": {
			"border": "border-2 border-dashed border-border",
			"radius": "rounded-xl",
			"activeState": "border-primary bg-primary/5",
			"icon": "FolderOpen at size 48"
		}
	}
}
