			"ring": { "oklch": "oklch(0.705 0.015 286.067)", "hex": "#a8a8b8", "role": "Focus ring" },
			"sidebar": { "oklch": "oklch(0.985 0 0)", "hex": "#fafafa", "role": "Sidebar background" },
			"sidebarForeground": {
				"oklch": "oklch(0.141 0.005 285.823)",
