{
	"meta": {
		"project": "Roka",
		"version": "1.0.0",
		"colorSpace": "oklch (CSS custom properties) with hex approximations for reference",
		"stack": "SvelteKit 5 + Tailwind CSS v4 + shadcn-svelte + bits-ui"
	},

